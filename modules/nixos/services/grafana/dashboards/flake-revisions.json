{
  "annotations": { "list": [] },
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "links": [],
  "panels": [
    {
      "title": "Configuration Lag",
      "description": "How far behind each machine is from the latest flake commit",
      "type": "bargauge",
      "gridPos": { "h": 10, "w": 12, "x": 0, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 86400 },
              { "color": "orange", "value": 259200 },
              { "color": "red", "value": 604800 }
            ]
          },
          "min": 0
        },
        "overrides": []
      },
      "options": {
        "orientation": "horizontal",
        "displayMode": "gradient",
        "reduceOptions": {
          "calcs": ["lastNotNull"],
          "fields": "",
          "values": false
        },
        "showUnfilled": true,
        "valueMode": "color",
        "sizing": "auto",
        "minVizWidth": 8,
        "minVizHeight": 16,
        "namePlacement": "auto"
      },
      "targets": [
        {
          "expr": "max(nixos_flake_latest_commit_timestamp) - on() group_right max by (instance) (node_nixos_configuration_timestamp)",
          "legendFormat": "{{ instance }}",
          "refId": "A"
        }
      ],
      "transformations": [
        {
          "id": "renameByRegex",
          "options": {
            "regex": "^([^.]+)\\..*",
            "renamePattern": "$1"
          }
        }
      ]
    },
    {
      "title": "Staleness Over Time",
      "description": "Configuration age per machine over time",
      "type": "timeseries",
      "gridPos": { "h": 10, "w": 12, "x": 12, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "custom": {
            "lineWidth": 2,
            "fillOpacity": 10,
            "gradientMode": "scheme",
            "showPoints": "never",
            "thresholdsStyle": { "mode": "off" }
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 86400 },
              { "color": "orange", "value": 259200 },
              { "color": "red", "value": 604800 }
            ]
          },
          "color": { "mode": "continuous-GrYlRd" }
        },
        "overrides": []
      },
      "options": {
        "tooltip": { "mode": "multi", "sort": "desc" },
        "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["lastNotNull"] }
      },
      "targets": [
        {
          "expr": "time() - max by (instance) (node_nixos_configuration_timestamp)",
          "legendFormat": "{{ instance }}",
          "refId": "A"
        }
      ],
      "transformations": [
        {
          "id": "renameByRegex",
          "options": {
            "regex": "^([^.]+)\\..*",
            "renamePattern": "$1"
          }
        }
      ]
    },
    {
      "title": "Machine Details",
      "description": "Detailed revision info per machine",
      "type": "table",
      "gridPos": { "h": 10, "w": 24, "x": 0, "y": 10 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [
        {
          "expr": "label_replace(label_replace(label_replace((last_over_time(node_nixos_configuration_timestamp[1y]) == on(instance) group_left max by(instance) (last_over_time(node_nixos_configuration_timestamp[1y]))) * 1000, \"deployed_commit\", \"$1\", \"revision\", \"(.{7}).*\"), \"revision\", \"\", \"revision\", \".*\"), \"instance\", \"$1\", \"instance\", \"([^.]+).*\")",
          "format": "table",
          "instant": true,
          "refId": "A"
        },
        {
          "expr": "label_replace(label_replace(label_replace((max by(instance) (last_over_time(node_nixos_configuration_timestamp[1y])) * 0 + on() group_left(revision) nixos_flake_latest_commit_timestamp) * 1000, \"latest_commit\", \"$1\", \"revision\", \"(.{7}).*\"), \"revision\", \"\", \"revision\", \".*\"), \"instance\", \"$1\", \"instance\", \"([^.]+).*\")",
          "format": "table",
          "instant": true,
          "refId": "B"
        },
        {
          "expr": "label_replace(last_over_time(nixos_flake_latest_commit_count[1y]) - on() group_right max by(instance) (last_over_time(node_nixos_configuration_revcount[1y])), \"instance\", \"$1\", \"instance\", \"([^.]+).*\")",
          "format": "table",
          "instant": true,
          "refId": "C"
        }
      ],
      "transformations": [
        {
          "id": "merge",
          "options": {}
        },
        {
          "id": "filterFieldsByName",
          "options": {
            "include": {
              "names": ["instance", "deployed_commit", "Value #A", "latest_commit", "Value #B", "Value #C"]
            }
          }
        },
        {
          "id": "organize",
          "options": {
            "renameByName": {
              "instance": "Machine",
              "Value #A": "Deployed",
              "deployed_commit": "Deployed Commit",
              "Value #C": "Commits Behind",
              "latest_commit": "Latest Commit",
              "Value #B": "Latest Commit Time"
            },
            "indexByName": {
              "instance": 0,
              "Value #A": 1,
              "deployed_commit": 2,
              "Value #C": 3,
              "latest_commit": 4,
              "Value #B": 5
            }
          }
        }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": {
            "filterable": false,
            "inspect": false
          }
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "Machine" },
            "properties": [
              { "id": "custom.width", "value": 120 }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "Deployed" },
            "properties": [
              { "id": "unit", "value": "dateTimeFromNow" },
              { "id": "custom.width", "value": 150 }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "Deployed Commit" },
            "properties": [
              { "id": "custom.width", "value": 120 }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "Commits Behind" },
            "properties": [
              { "id": "custom.width", "value": 120 }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "Latest Commit" },
            "properties": [
              { "id": "custom.width", "value": 120 }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "Latest Commit Time" },
            "properties": [
              { "id": "unit", "value": "dateTimeFromNow" },
              { "id": "custom.width", "value": 150 }
            ]
          }
        ]
      }
    }
  ],
  "schemaVersion": 39,
  "tags": ["nixos", "flake"],
  "templating": {
    "list": [
      {
        "current": {},
        "hide": 0,
        "includeAll": false,
        "name": "DS_PROMETHEUS",
        "query": "prometheus",
        "type": "datasource"
      }
    ]
  },
  "time": { "from": "now-7d", "to": "now" },
  "title": "NixOS Flake Revisions",
  "uid": "nixos-flake-revisions"
}
